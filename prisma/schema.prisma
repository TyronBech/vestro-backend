datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           String  @id @default(uuid())
  email        String  @unique
  name         String?
  passwordHash String?

  // ── 2FA (Google Authenticator / TOTP) ──
  twoFactorSecret String?
  is2FAEnabled    Boolean @default(false)

  // ── Biometrics (FaceID / Fingerprint) ──
  biometricsEnabled Boolean @default(false)
  biometricKeyHash  String?

  // ── Security Toggles ──
  panicModeEnabled Boolean @default(false)
  spendingLimit    Float?

  // ── Password Reset ──
  resetPasswordToken   String?
  resetPasswordExpires DateTime?

  // ── Activity Tracking ──
  lastActiveAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ── Relations to the Poverty Firewall System ──
  budgetConfig BudgetConfig?
  creditCards  CreditCard[]
  sweepLogs    SweepLog[]
  macroAssets  MacroAsset[]
}

model BudgetConfig {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  netSalary       Float // Baseline salary (e.g., 25000)
  needsRate       Float @default(0.50) // 50%
  wantsRate       Float @default(0.30) // 30%
  savingsRate     Float @default(0.10) // 10%
  investmentsRate Float @default(0.10) // 10%

  cashAmount Float // Needs: Cash Portion (rent)
  updatedAt  DateTime @updatedAt
}

model CreditCard {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  cardName           String // e.g., "UnionBank U Card"
  creditLimit        Float // e.g., 20000
  statementCutoffDay Int // Day of month statement is generated (e.g., 15)
  paymentDueDay      Int // Day of month payment is due (e.g., 5)
  unbilledSpend      Float  @default(0.0) // Track current unbilled swiped amount
  midCyclePaid       Float  @default(0.0) // Amount paid early to drop statement balance

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SweepLog {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  amount      Float // Amount swept out of Wants
  targetVault String // Bank to store the amount
  notes       String? // e.g., "Skipped Steam sale this month"
  sweptAt     DateTime @default(now())
}

model MacroAsset {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  bankName   String // "LANDBANK", "BPI"
  purpose    String // e.g., "Emergency Fund", "Wants Sandbox", "Rent Reservoir"
  balance    Float    @default(0.0)
  targetGoal Float? // Sinking fund target
  updatedAt  DateTime @updatedAt
}
